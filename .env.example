# Copy this file to .env and fill in the values from your Firebase project:
# Firebase Console → Project settings → General → Your apps → SDK setup and
# configuration → "Config".
#
# These values are safe to expose in client-side code (they identify your
# Firebase project, they are not secrets) — but .env is still gitignored by
# default here so you don't have to think about it.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
